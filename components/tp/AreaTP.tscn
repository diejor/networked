[sub_resource type="GDScript" id="GDScript_ffavr"]
script/source = "@tool
extends Node

@onready var area_tp: AreaTP = $\"../..\"
@onready var debug_label: DebugLabel = $\"..\"

func _ready() -> void:
	var data := {
		area = area_tp.scene_name,
		id = area_tp.target_tp_id
	}
	debug_label.text = \"scene: {area}
			tp_id: {id}\".format(data)
"

