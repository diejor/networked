# Godot 4+ specific ignores
.godot/
/android/
/reports

addons/gdUnit4/GdUnitRunner.cfg

tmp_saves
tmp_save
saves
save

# Ignore temporary files starting with a tilde (like your ~libwebrtc...dll)
~*

# Optional: Ignore backup/temp files ending with a tilde (common in many editors)
*~
# Docs build outputs
docs/_build/
docs/api/
docs/api_filtered/
docs/classes/
docs/sphinx_warnings.txt

# docs/tools/make_rst.py is generated by build_make_rst.py from vendor +
# patches/. We keep it tracked (like a lockfile) so contributors can read it
# without running the build; CI verifies via `build_make_rst.py --check`.
# To regenerate after editing a patch:  python tools/build_make_rst.py
